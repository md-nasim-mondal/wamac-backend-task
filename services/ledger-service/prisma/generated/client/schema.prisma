generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model LedgerEntry {
  id            String   @id @default(uuid()) @map("entry_id")
  transactionId String   @map("transaction_id")
  accountId     String   @map("account_id")
  debitAmount   Decimal  @default(0) @map("debit_amount") @db.Decimal(18, 4)
  creditAmount  Decimal  @default(0) @map("credit_amount") @db.Decimal(18, 4)
  currency      String   @map("currency")
  fxQuoteId     String?  @map("fx_quote_id")
  fxRate        Decimal? @map("fx_rate") @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([accountId])
}
